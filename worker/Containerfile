FROM python:3.12-slim

# Install Node.js 22.x (required by Claude Code CLI)
RUN apt-get update && \
    apt-get install -y --no-install-recommends ca-certificates curl gnupg && \
    mkdir -p /etc/apt/keyrings && \
    curl -fsSL https://deb.nodesource.com/gpgkey/nodesource-repo.gpg.key \
      | gpg --dearmor -o /etc/apt/keyrings/nodesource.gpg && \
    echo "deb [signed-by=/etc/apt/keyrings/nodesource.gpg] https://deb.nodesource.com/node_22.x nodistro main" \
      > /etc/apt/sources.list.d/nodesource.list && \
    apt-get update && \
    apt-get install -y --no-install-recommends nodejs && \
    apt-get clean && rm -rf /var/lib/apt/lists/*

# Install Claude Code CLI (Agent SDK spawns it as a subprocess)
RUN npm install -g @anthropic-ai/claude-code

# Install Python Agent SDK
RUN pip install --no-cache-dir claude-agent-sdk sqlite-vec

WORKDIR /app
COPY worker.py agent.py db.py embed.py search.py __init__.py ./worker/
COPY migrations/ ./worker/migrations/
ENV PYTHONPATH=/app
CMD ["python", "-u", "-m", "worker.worker"]
