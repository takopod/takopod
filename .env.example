# Claude auth — set EITHER CLAUDE_CODE_OAUTH_TOKEN (Pro/Max subscription) OR
# the GOOGLE_CLOUD_* vars (Vertex AI). If both are set, the OAuth token wins.

# Claude subscription OAuth token. Generate with: claude setup-token
CLAUDE_CODE_OAUTH_TOKEN=

# Google Cloud / Vertex AI
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_REGION=
